{
    "name": "v-venve",
    "version": "1.0.0",
    "description": "VVenve 是一个开源的 CCW 安全审计工具。",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "run-p dev:watch dev:run",
        "dev:watch": "tsup --watch --env.NODE_ENV development",
        "dev:run": "tsc test/index.ts && node test/index.js",
        "dev:tsc": "tsc --watch",
        "build": "tsup --env.NODE_ENV production",
        "build:tsc": "tsc",
        "lint": "run-s lint:*",
        "lint:es": "eslint . --fix",
        "lint:type": "tsc --noEmit",
        "postinstall": "git submodule update --init && cd src/nine && pnpm install && pnpm build && cd ../scratch-obtain && pnpm install && pnpm build"
    },
    "keywords": [],
    "author": "陨落基围虾",
    "license": "MIT",
    "packageManager": "pnpm@10.28.2",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@turbowarp/types": "^0.0.14",
        "@types/node": "^25.3.3",
        "eslint": "^10.0.2",
        "globals": "^17.3.0",
        "jiti": "^2.6.1",
        "npm-run-all": "^4.1.5",
        "playwright": "^1.58.2",
        "svg-to-dataurl": "^1.0.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}